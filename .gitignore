# Ignore local .terraform directories (where the heavy plugins live)
**/.terraform/

# .tfstate files (CRITICAL: These can contain plain-text passwords!)
*.tfstate
*.tfstate.*

# Ignore variables files (if you use them for secrets later)
*.tfvars
*.tfvars.json

# Crash log files
crash.log
crash.*.log

# Ignore Terraform provider binaries explicitly
**/registry.terraform.io/

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# OS or Editor folders
.DS_Store
.vscode/
.idea/
*.swp

# ========================
# Next.js & Node (Portal)
# ========================
node_modules/
.next/
out/
next-env.d.ts
npm-debug.log*

# ALWAYS ignore local environment files!
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# DuckDB WASM binaries
apps/portal/public/duckdb-*.wasm
apps/portal/public/duckdb-browser-*.js